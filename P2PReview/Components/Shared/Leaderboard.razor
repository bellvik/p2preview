@using P2PReview.Client.Models

<div class="leaderboard-card">
    <h3>Таблица лидеров</h3>

    <div class="leaderboard-list">
        @if (Users != null && Users.Any())
        {
            @for (int i = 0; i < Users.Count && i < 10; i++)
            {
                var user = Users[i];
                <div class="leaderboard-item @(i < 3 ? "top-three" : "")">
                    <span class="rank @(i < 3 ? $"rank-{i + 1}" : "")">
                        @(i + 1)
                    </span>
                    <i class="fas fa-user-circle user-icon"></i>
                    <span class="username" title="@user.Name">@user.Name</span>
                    <span class="xp">@user.XP.ToString("N0")</span>
                </div>
            }
        }
        else
        {
            <p style="color: #718096; text-align: center; padding: 20px; font-size: 13px;">
                Загрузка...
            </p>
        }
    </div>

    @if (CurrentUser != null)
    {
        <div class="leaderboard-item current-user">
            <span class="rank">@CurrentUser.Rank</span>
            <i class="fas fa-user-circle user-icon"></i>
            <span class="username">Вы</span>
            <span class="xp">@CurrentUser.XP.ToString("N0")</span>
        </div>
    }
</div>

@code {
    [Parameter] public List<User> Users { get; set; } = new();
    [Parameter] public User? CurrentUser { get; set; }
}