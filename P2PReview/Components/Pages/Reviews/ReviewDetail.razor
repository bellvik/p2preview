@page "/reviews/{ReviewId:int}"
@rendermode InteractiveServer
@using P2PReview.Client.Models
@using P2PReview.Client.Services.Interfaces
@using Microsoft.AspNetCore.Components
@inject NavigationManager NavigationManager
@inject IReviewService ReviewService
@inject ICommentService CommentService
@inject IJSRuntime JS

<PageTitle>Code Review - P2P Review</PageTitle>

<div class="review-page">
    <!-- Header -->
    <header class="review-header">
        <div class="header-left">
            <button class="btn-back" @onclick="GoBack">
                <i class="fas fa-arrow-left"></i>
            </button>
            <div class="project-info">
                <h1>@review?.ProjectName</h1>
                <div class="project-meta">
                    <span class="meta-item">
                        <i class="fas fa-file-code"></i>
                        @review?.FileCount файлов
                    </span>
                    <span class="meta-item">
                        <i class="fas fa-clock"></i>
                        Дней осталось: @review?.DueDays
                    </span>
                </div>
            </div>
        </div>
        <div class="header-right">
            <button class="btn btn-outline" @onclick="SaveProgress">
                <i class="fas fa-save"></i>
                Сохранить
            </button>
            <button class="btn btn-primary" @onclick="CompleteReview">
                <i class="fas fa-check"></i>
                Завершить ревью
            </button>
        </div>
    </header>

    <!-- Main Content -->
    <div class="review-content">
        <!-- Left Panel: Code Editor -->
        <div class="code-panel">
            <div class="code-header">
                <h3>Backend-API auth-refactor</h3>
                <div class="tech-stack">
                    @if (review?.Technologies != null)
                    {
                        @foreach (var tech in review.Technologies)
                        {
                            <span class="tech-badge @tech.ToLower()">@tech</span>
                        }
                    }
                </div>
                <a href="@reviewRepoUrl" class="repo-link" target="_blank">
                    <i class="fab fa-github"></i>
                    github.com/example/repo
                </a>
            </div>

            <div class="code-editor">
                <div class="line-numbers">
                    @for (int i = 1; i <= codeLines.Count; i++)
                    {
                        <div class="line-number @(i == selectedLine ? "selected" : "")
                                    @(lineHasComment(i) ? "has-comment" : "")"
                             @onclick="() => SelectLine(i)">
                            @i
                            @if (lineHasComment(i))
                            {
                                <i class="fas fa-comment-dots comment-indicator"></i>
                            }
                        </div>
                    }
                </div>
                <div class="code-content">
                    @for (int i = 0; i < codeLines.Count; i++)
                    {
                        var lineNum = i + 1;
                        <div class="code-line @(lineNum == selectedLine ? "selected" : "")"
                             @onclick="() => SelectLine(lineNum)">
                            <pre>@codeLines[i]</pre>
                        </div>
                    }
                </div>

                <!-- Comment Popup -->
                @if (showCommentPopup && selectedLine > 0)
                {
                    <div class="comment-popup" style="top: @(Math.Min(selectedLine * 28 + 80, 500))px; left: 450px;">
                        <div class="popup-header">
                            <span>Комментарий к строке @selectedLine</span>
                            <button class="btn-close" @onclick="CloseCommentPopup">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>

                        <textarea @bind="commentText"
                                  placeholder="Введите комментарий..."
                                  rows="3"
                                  class="comment-input"></textarea>

                        <div class="comment-categories">
                            @foreach (var cat in commentCategories)
                            {
                                <button class="category-btn @(selectedCategory == cat.Key ? "selected" : "")"
                                        @onclick="() => SelectCategory(cat.Key)"
                                        title="@cat.Value.Description">
                                    <i class="@cat.Value.Icon"></i>
                                    @cat.Value.Label
                                </button>
                            }
                        </div>

                        <button class="btn btn-submit" @onclick="SubmitComment" disabled="@string.IsNullOrWhiteSpace(commentText)">
                            <i class="fas fa-paper-plane"></i>
                            Отправить
                        </button>
                    </div>
                }

                <!-- Existing Comments for Line -->
                @if (existingComments.Any() && selectedLine > 0)
                {
                    <div class="existing-comments" style="top: @(Math.Min(selectedLine * 28 + 80, 400))px; left: 50px;">
                        <h4>Комментарии (@existingComments.Count)</h4>
                        @foreach (var comment in existingComments)
                        {
                            <div class="comment-item">
                                <div class="comment-header">
                                    <span class="comment-author">@comment.AuthorName</span>
                                    <span class="comment-category @comment.Category.ToLower()">
                                        <i class="@GetCategoryIcon(comment.Category)"></i>
                                        @GetCategoryLabel(comment.Category)
                                    </span>
                                </div>
                                <p class="comment-text">@comment.Text</p>
                                <div class="comment-meta">
                                    <span class="comment-time">@comment.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                                    <button class="btn-delete-comment" @onclick="() => DeleteComment(comment.Id)">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Right Panel: Summary Review -->
        <div class="summary-panel">
            <h3>Summary-review</h3>

            <div class="summary-section">
                <label>Общая оценка архитектуры</label>
                <textarea @bind="architectureComment"
                          placeholder="Введите комментарий..."
                          rows="3"></textarea>
            </div>

            <div class="summary-section">
                <label>Оценка читаемости</label>
                <div class="rating-slider">
                    <input type="range" min="1" max="5" step="1" @bind="readabilityRating" />
                    <div class="rating-labels">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <span>@i</span>
                        }
                    </div>
                </div>
            </div>

            <div class="summary-section">
                <label>Оценка тестируемости</label>
                <div class="rating-slider">
                    <input type="range" min="1" max="5" step="1" @bind="testabilityRating" />
                    <div class="rating-labels">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <span>@i</span>
                        }
                    </div>
                </div>
            </div>

            <div class="summary-section">
                <label>Оценка масштабируемости</label>
                <div class="rating-slider">
                    <input type="range" min="1" max="5" step="1" @bind="scalabilityRating" />
                    <div class="rating-labels">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <span>@i</span>
                        }
                    </div>
                </div>
            </div>

            <button class="btn btn-primary btn-complete" @onclick="CompleteReview">
                <i class="fas fa-check-circle"></i>
                Завершить ревью
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] public int ReviewId { get; set; }

    private Review? review;
    private string reviewRepoUrl = "https://github.com/example/repo";
    private bool showCommentPopup = false;
    private int selectedLine = 0;
    private string commentText = "";
    private string selectedCategory = "";
    private List<CodeComment> allComments = new();
    private List<CodeComment> existingComments = new();

    private string architectureComment = "";
    private int readabilityRating = 3;
    private int testabilityRating = 3;
    private int scalabilityRating = 3;
    private int securityRating = 3;

    private List<string> codeLines = new()
    {
        "def selection_sort(arr):",
        "    for i in range(len(arr)):",
        "        min_index = i",
        "        for j in range(i + 1, len(arr)):",
        "            if arr[j] < arr[min_index]:",
        "                min_index = j",
        "    if min_index != i:",
        "        arr[i], arr[min_index] = arr[min_index], arr[i]",
        "    return arr",
        "",
        "# Test the function",
        "test_array = [64, 25, 12, 22, 11]",
        "print(f'Original: {test_array}')",
        "sorted_array = selection_sort(test_array)",
        "print(f'Sorted: {sorted_array}')",
        "",
        "# Time Complexity: O(n²)",
        "# Space Complexity: O(1)"
    };

    private Dictionary<string, CommentCategoryInfo> commentCategories = new()
    {
        { "bug", new CommentCategoryInfo { Icon = "fas fa-bug", Label = "Bug", Description = "Ошибка в коде", Color = "#e53e3e" } },
        { "performance", new CommentCategoryInfo { Icon = "fas fa-tachometer-alt", Label = "Performance", Description = "Производительность", Color = "#dd6b20" } },
        { "security", new CommentCategoryInfo { Icon = "fas fa-shield-alt", Label = "Security", Description = "Безопасность", Color = "#d69e2e" } },
        { "architecture", new CommentCategoryInfo { Icon = "fas fa-sitemap", Label = "Architecture", Description = "Архитектура", Color = "#3182ce" } },
        { "codestyle", new CommentCategoryInfo { Icon = "fas fa-code", Label = "Code Style", Description = "Стиль кода", Color = "#805ad5" } },
        { "bestpractice", new CommentCategoryInfo { Icon = "fas fa-check-circle", Label = "Best Practice", Description = "Лучшие практики", Color = "#38a169" } },
        { "refactoring", new CommentCategoryInfo { Icon = "fas fa-tools", Label = "Refactoring", Description = "Рефакторинг", Color = "#319795" } }
    };

    protected override async Task OnInitializedAsync()
    {
        review = await ReviewService.GetReviewByIdAsync(ReviewId);
        if (review == null)
        {
            NavigationManager.NavigateTo("/");
        }

        // Загрузить существующие комментарии
        allComments = await CommentService.GetCommentsForReviewAsync(ReviewId);
    }

    private bool lineHasComment(int lineNumber)
    {
        return allComments.Any(c => c.LineNumber == lineNumber);
    }

    private void SelectLine(int lineNum)
    {
        selectedLine = lineNum;
        showCommentPopup = true;
        existingComments = allComments.Where(c => c.LineNumber == lineNum).ToList();
        commentText = "";
        selectedCategory = "";
    }

    private void CloseCommentPopup()
    {
        showCommentPopup = false;
        selectedLine = 0;
        commentText = "";
        selectedCategory = "";
        existingComments = new();
    }

    private void SelectCategory(string category)
    {
        selectedCategory = category;
    }

    private async Task SubmitComment()
    {
        if (string.IsNullOrWhiteSpace(commentText))
            return;

        var comment = new CodeComment
            {
                ReviewId = ReviewId,
                LineNumber = selectedLine,
                Text = commentText,
                Category = selectedCategory,
                AuthorName = "You",
                FileName = "sort.py"
            };

        await CommentService.AddCommentAsync(comment);

        // Обновить список комментариев
        allComments = await CommentService.GetCommentsForReviewAsync(ReviewId);
        existingComments = allComments.Where(c => c.LineNumber == selectedLine).ToList();

        // Очистить форму
        commentText = "";
        selectedCategory = "";
    }

    private async Task DeleteComment(int commentId)
    {
        await CommentService.DeleteCommentAsync(commentId);
        allComments = await CommentService.GetCommentsForReviewAsync(ReviewId);
        existingComments = allComments.Where(c => c.LineNumber == selectedLine).ToList();
    }

    private async Task SaveProgress()
    {
        await JS.InvokeVoidAsync("alert", "Прогресс сохранён!");
    }

    private async Task CompleteReview()
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Завершить ревью?");
        if (confirmed)
        {
            NavigationManager.NavigateTo("/");
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/");
    }

    private string GetCategoryIcon(string category)
    {
        return commentCategories.TryGetValue(category.ToLower(), out var info) ? info.Icon : "fas fa-comment";
    }

    private string GetCategoryLabel(string category)
    {
        return commentCategories.TryGetValue(category.ToLower(), out var info) ? info.Label : category;
    }

    public class CommentCategoryInfo
    {
        public string Icon { get; set; } = "";
        public string Label { get; set; } = "";
        public string Description { get; set; } = "";
        public string Color { get; set; } = "";
    }
}